{
    "name": "Django K3s Development",
    "build": {
        "dockerfile": "Dockerfile.dev",
        "context": ".."
    },
    "mounts": [
        // Mount source code for live editing
        "source=${localWorkspaceFolder},target=/webapp,type=bind,consistency=cached",
        // Mount Docker socket for Telepresence (if needed)
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
        // Mount kubectl config 
        "source=${localEnv:HOME}/.kube,target=/root/.kube,type=bind,consistency=cached",
        // For github auth
        "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,consistency=cached"

    ],
    "workspaceFolder": "/webapp",
    "containerEnv": {
        "PYTHONPATH": "/webapp"
    },
    "runArgs": [
        "--network=host",
        "--privileged",
        "--env-file=.devcontainer/.env"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.debugpy",
                "ms-python.pylint",
                "ms-python.black-formatter",
                "ms-vscode.vscode-json"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.terminal.activateEnvironment": false,
                "python.formatting.provider": "black"
            }
        }
    },
    "remoteUser": "root",
    "features": {
        "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
            "version": "latest"
        }
    }
}


// this is all inside .devcontaier, so a custom development image can be span, inherited from the prod dockerfile
// so development can be done within the container on live code for git and instant changes
// telepresence will also be used so it can connect to the existing services within the cluster so you can test the full functionality

// inherit the dockerfile
//  for the dockerfile, mount the code instead of copying it, for live code editing
